{
    "compilerOptions": {
        "target": "ES2017",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowJs": false,
        "lib": ["dom", "es7"]
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["./assets", "./ios", "./android", "./scripts", "./dist", "./i18n"]
}
